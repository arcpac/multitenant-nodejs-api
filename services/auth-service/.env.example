
PORT=4001
DATABASE_URL=postgres://name:<pass>@localhost:5433/name

ACCESS_TOKEN_SECRET=secret
REFRESH_TOKEN_SECRET=secret
ACCESS_TOKEN_TTL=10s
REFRESH_TOKEN_TTL_DAYS=14

# Login brute-force guards
LOGIN_LIMIT_IP_WINDOW_SEC=900
LOGIN_LIMIT_IP_MAX=120
LOGIN_LIMIT_IP_EMAIL_WINDOW_SEC=900
LOGIN_LIMIT_IP_EMAIL_MAX=10
LOGIN_LIMIT_EMAIL_WINDOW_SEC=3600
LOGIN_LIMIT_EMAIL_MAX=30
