# Leave empty to use Vite dev proxy (/auth, /api, /ai, /tasks, /graphql).
# VITE_AUTH_BASE_URL=
# VITE_TASK_BASE_URL=

# Set this to send auth requests directly to auth-service (helpful for Burp):
# Applies only to /auth/* and /api/* requests.
# VITE_AUTH_BASE_URL=http://127.0.0.1:4001

# Set this to send task-service requests directly to task-service:
# Applies to /ai/*, /tasks/*, and /graphql.
# VITE_TASK_BASE_URL=http://127.0.0.1:4002
